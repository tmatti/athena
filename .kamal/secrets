# Kamal secrets (https://kamal-deploy.org/docs/commands/secrets/).
#
# This file IS checked into git, so it must only ever reference environment
# variables or a secret-manager adapter -- never literal values.
#
# Secrets are pulled from 1Password: one item (Athena/deploy) with one field
# per secret. Requires the `op` CLI and OP_ACCOUNT exported in the deploy
# shell (your account shorthand from `op account list`). See the README for
# the one-time `op vault create` / `op item create` setup.

SECRETS=$(kamal secrets fetch --adapter 1password --account $OP_ACCOUNT --from op://Athena/deploy KAMAL_REGISTRY_PASSWORD DATABASE_URL BRAIN_API_KEY EMBEDDING_API_KEY POSTGRES_PASSWORD CLOUDFLARE_ORIGIN_CERT CLOUDFLARE_ORIGIN_KEY)

KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
DATABASE_URL=$(kamal secrets extract DATABASE_URL ${SECRETS})
BRAIN_API_KEY=$(kamal secrets extract BRAIN_API_KEY ${SECRETS})
EMBEDDING_API_KEY=$(kamal secrets extract EMBEDDING_API_KEY ${SECRETS})
POSTGRES_PASSWORD=$(kamal secrets extract POSTGRES_PASSWORD ${SECRETS})
CLOUDFLARE_ORIGIN_CERT=$(kamal secrets extract CLOUDFLARE_ORIGIN_CERT ${SECRETS})
CLOUDFLARE_ORIGIN_KEY=$(kamal secrets extract CLOUDFLARE_ORIGIN_KEY ${SECRETS})

# Not sensitive, just deployment-specific: the public HTTPS origin that
# enables OAuth for MCP clients (docs/oauth.md). Exported in the deploy shell
# alongside ATHENA_HOST/ATHENA_SERVER_IP rather than stored in 1Password;
# leave it unset to run static-key-only.
PUBLIC_BASE_URL=$PUBLIC_BASE_URL

# No 1Password? Delete everything above and read from the shell environment
# instead (export each variable before deploying):
#
#   KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
#   DATABASE_URL=$DATABASE_URL
#   BRAIN_API_KEY=$BRAIN_API_KEY
#   EMBEDDING_API_KEY=$EMBEDDING_API_KEY
#   POSTGRES_PASSWORD=$POSTGRES_PASSWORD
#   CLOUDFLARE_ORIGIN_CERT=$CLOUDFLARE_ORIGIN_CERT
#   CLOUDFLARE_ORIGIN_KEY=$CLOUDFLARE_ORIGIN_KEY
#
# (PUBLIC_BASE_URL below already reads from the shell environment.)
